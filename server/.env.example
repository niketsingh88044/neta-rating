PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/neta_rating
JWT_SECRET=replace_this_with_a_long_random_string
JWT_EXPIRES=7d
CLIENT_ORIGIN=http://localhost:5173

# Public URL of the frontend — used to build verification links sent in emails.
APP_URL=http://localhost:5173

# SMTP for email verification. If any of SMTP_HOST/PORT/USER/PASS is missing,
# verification emails are printed to the server console instead of being sent.
# Gmail example: host=smtp.gmail.com, port=587, user=you@gmail.com, pass=<16-char app password>.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Neta Rating <no-reply@neta-rating.local>"
